{{ 'snippet-sticky-cart-bar.css' | asset_url | stylesheet_tag }}

<sticky-cart-bar class="sticky-cart-bar">
  <div class="page-width sticky-cart-bar__inner">
    <div class="sticky-cart-bar__product-info">
      {%- if product.featured_image != blank -%}
        <div class="sticky-cart-bar__image">
          <img src="{{ product.featured_image | image_url: width: 100 }}" alt="{{ product.title | escape }}" loading="lazy" width="50" height="50">
        </div>
      {%- endif -%}
      <div class="sticky-cart-bar__details">
        <span class="sticky-cart-bar__title">{{ product.title | escape }}</span>
        <div class="sticky-cart-bar__price" id="sticky-price-{{ section.id }}">
          {% render 'price', product: product, use_variant: true, show_badges: false %}
        </div>
      </div>
    </div>
    
    <div class="sticky-cart-bar__actions">
      <button type="button" class="button button--primary sticky-cart-bar__button" onclick="document.querySelector('.product-form__submit').click();">
        In den Warenkorb
      </button>
    </div>
  </div>
</sticky-cart-bar>

<script>
  class StickyCartBar extends HTMLElement {
    constructor() {
      super();
      this.init();
    }

    init() {
      // Find the main add to cart button in the product form
      const mainAddToCart = document.querySelector('.product-form__submit');
      if (!mainAddToCart) return;

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          // If the button is NO longer intersecting AND it has scrolled past the top
          if (!entry.isIntersecting && entry.boundingClientRect.top < 0) {
            this.classList.add('is-visible');
          } else {
            this.classList.remove('is-visible');
          }
        });
      }, { threshold: 0 });

      observer.observe(mainAddToCart);
    }
  }
  customElements.define('sticky-cart-bar', StickyCartBar);
</script>
