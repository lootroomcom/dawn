{%- comment -%}
  Snippet: bg-animation-v2.liquid
  Dynamic Cyberpunk Background with Performance optimizations.
{%- endcomment -%}

{%- if settings.lrb_enable -%}
  {{ 'section-cyber-background.css' | asset_url | stylesheet_tag }}
  
  {%- assign blue_rgb = settings.lrb_accent_blue.red | append: ', ' | append: settings.lrb_accent_blue.green | append: ', ' | append: settings.lrb_accent_blue.blue -%}
  {%- assign green_rgb = settings.lrb_accent_green.red | append: ', ' | append: settings.lrb_accent_green.green | append: ', ' | append: settings.lrb_accent_green.blue -%}
  
  <div id="lootroom-bg" class="{% if settings.lrb_performance_mode %}lrb-perf-mode{% endif %}" aria-hidden="true" style="--lrb-bg: {{ settings.lrb_bg_color | default: '#070b14' }}; --lrb-blue: {{ settings.lrb_accent_blue | default: '#00a3ff' }}; --lrb-blue-rgb: {{ blue_rgb }}; --lrb-green: {{ settings.lrb_accent_green | default: '#22c55e' }}; --lrb-green-rgb: {{ green_rgb }};">
    
    <!-- Blauer Radial-Glow -->
    <div class="lrb-blue-glow"></div>
  
    <!-- Blur-Orb Blau -->
    <div class="lrb-orb lrb-orb--blue"></div>
  
    <!-- Blur-Orb Grün -->
    <div class="lrb-orb lrb-orb--green"></div>
  
    <!-- Lila/Pink Gradient unten Mitte -->
    <div class="lrb-bottom-glow"></div>
  
    <!-- Feines Linien-Grid -->
    <div class="lrb-grid"></div>
  
    <!-- Subtile Scanlines -->
    <div class="lrb-scanlines"></div>
  
    <!-- Retro Perspective Grid am Boden -->
    <div class="lrb-retro-grid-wrap">
      <div class="lrb-retro-grid"></div>
      <div class="lrb-retro-grid-fade"></div>
    </div>
  
    <!-- Floating Geometric Shapes -->
    <div class="lrb-shapes">
      <!-- Hexagon oben links -->
      <div class="lrb-shape lrb-hex" style="top:22%;left:10%;width:6.4rem;height:6.4rem;animation-delay:0s">
        <svg viewBox="0 0 100 100" width="100%" height="100%">
          <polygon points="50,5 95,27.5 95,72.5 50,95 5,72.5 5,27.5"
            fill="none" stroke="{{ settings.lrb_accent_blue | default: '#00a3ff' }}" stroke-width="2" opacity="0.2"/>
        </svg>
      </div>
      <!-- Dreieck oben rechts -->
      <div class="lrb-shape lrb-float-delayed" style="top:28%;right:15%;width:4.8rem;height:4.8rem;animation-delay:0.5s">
        <svg viewBox="0 0 100 100" width="100%" height="100%">
          <polygon points="50,10 90,90 10,90"
            fill="none" stroke="{{ settings.lrb_accent_green | default: '#22c55e' }}" stroke-width="2" opacity="0.15"/>
        </svg>
      </div>
      <!-- Kreis mit Punkt links mitte -->
      <div class="lrb-shape lrb-spin-slow" style="bottom:35%;left:20%;width:8.0rem;height:8.0rem">
        <svg viewBox="0 0 100 100" width="100%" height="100%">
          <circle cx="50" cy="50" r="45" fill="none" stroke="{{ settings.lrb_accent_blue | default: '#00a3ff' }}" stroke-width="2" opacity="0.1"/>
          <circle cx="50" cy="10" r="5" fill="{{ settings.lrb_accent_blue | default: '#00a3ff' }}" opacity="0.2"/>
        </svg>
      </div>
      <!-- Rotation Square links oben -->
      <div class="lrb-shape lrb-float-reverse" style="top:48%;left:5%;width:4.0rem;height:4.0rem">
        <div style="width:100%;height:100%;border:2px solid rgba(var(--lrb-blue-rgb), 0.25);transform:rotate(45deg)"></div>
      </div>
      <!-- Plus rechts mitte -->
      <div class="lrb-shape lrb-pulse-slow" style="bottom:55%;right:10%;width:3.2rem;height:3.2rem">
        <svg viewBox="0 0 100 100" width="100%" height="100%">
          <line x1="50" y1="20" x2="50" y2="80" stroke="{{ settings.lrb_accent_green | default: '#22c55e' }}" stroke-width="8" opacity="0.2"/>
          <line x1="20" y1="50" x2="80" y2="50" stroke="{{ settings.lrb_accent_green | default: '#22c55e' }}" stroke-width="8" opacity="0.2"/>
        </svg>
      </div>
      <!-- Dot-Grid Muster rechts -->
      <div class="lrb-shape" style="top:48%;right:5%;opacity:0.1">
        <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:0.8rem">
          <div style="width:0.8rem;height:0.8rem;border-radius:50%;background:{{ settings.lrb_accent_blue | default: '#00a3ff' }};animation:lrb-pulse 2s infinite 0s"></div>
          <div style="width:0.8rem;height:0.8rem;border-radius:50%;background:{{ settings.lrb_accent_blue | default: '#00a3ff' }};animation:lrb-pulse 2s infinite 0.1s"></div>
          <div style="width:0.8rem;height:0.8rem;border-radius:50%;background:{{ settings.lrb_accent_blue | default: '#00a3ff' }};animation:lrb-pulse 2s infinite 0.2s"></div>
          <div style="width:0.8rem;height:0.8rem;border-radius:50%;background:{{ settings.lrb_accent_blue | default: '#00a3ff' }};animation:lrb-pulse 2s infinite 0.3s"></div>
          <div style="width:0.8rem;height:0.8rem;border-radius:50%;background:{{ settings.lrb_accent_blue | default: '#00a3ff' }};animation:lrb-pulse 2s infinite 0.4s"></div>
          <div style="width:0.8rem;height:0.8rem;border-radius:50%;background:{{ settings.lrb_accent_blue | default: '#00a3ff' }};animation:lrb-pulse 2s infinite 0.5s"></div>
          <div style="width:0.8rem;height:0.8rem;border-radius:50%;background:{{ settings.lrb_accent_blue | default: '#00a3ff' }};animation:lrb-pulse 2s infinite 0.6s"></div>
          <div style="width:0.8rem;height:0.8rem;border-radius:50%;background:{{ settings.lrb_accent_blue | default: '#00a3ff' }};animation:lrb-pulse 2s infinite 0.7s"></div>
          <div style="width:0.8rem;height:0.8rem;border-radius:50%;background:{{ settings.lrb_accent_blue | default: '#00a3ff' }};animation:lrb-pulse 2s infinite 0.8s"></div>
        </div>
      </div>
      <!-- Corner Bracket oben rechts -->
      <div class="lrb-shape lrb-float" style="top:25%;right:25%;width:6.4rem;height:6.4rem;opacity:0.2">
        <div style="position:relative;width:100%;height:100%">
          <div style="position:absolute;top:0;left:0;width:1.6rem;height:1.6rem;border-top:2px solid {{ settings.lrb_accent_blue | default: '#00a3ff' }};border-left:2px solid {{ settings.lrb_accent_blue | default: '#00a3ff' }}"></div>
          <div style="position:absolute;top:0;right:0;width:1.6rem;height:1.6rem;border-top:2px solid {{ settings.lrb_accent_blue | default: '#00a3ff' }};border-right:2px solid {{ settings.lrb_accent_blue | default: '#00a3ff' }}"></div>
          <div style="position:absolute;bottom:0;left:0;width:1.6rem;height:1.6rem;border-bottom:2px solid {{ settings.lrb_accent_blue | default: '#00a3ff' }};border-left:2px solid {{ settings.lrb_accent_blue | default: '#00a3ff' }}"></div>
          <div style="position:absolute;bottom:0;right:0;width:1.6rem;height:1.6rem;border-bottom:2px solid {{ settings.lrb_accent_blue | default: '#00a3ff' }};border-right:2px solid {{ settings.lrb_accent_blue | default: '#00a3ff' }}"></div>
        </div>
      </div>
      <!-- Ping dot oben links -->
      <div class="lrb-shape" style="top:35%;left:33%;opacity:0.3">
        <div style="width:0.8rem;height:0.8rem;border-radius:50%;background:{{ settings.lrb_accent_blue | default: '#00a3ff' }};animation:lrb-ping 1.5s cubic-bezier(0,0,0.2,1) infinite"></div>
      </div>
      <!-- Ping dot unten rechts -->
      <div class="lrb-shape" style="bottom:25%;right:33%;opacity:0.2">
        <div style="width:1.2rem;height:1.2rem;border-radius:50%;background:{{ settings.lrb_accent_green | default: '#22c55e' }};animation:lrb-ping 1.5s cubic-bezier(0,0,0.2,1) infinite 1s"></div>
      </div>
    </div>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', function() {
      document.body.classList.add('lrb-active');
    });
  </script>
{%- endif -%}
