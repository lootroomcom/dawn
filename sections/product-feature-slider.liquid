{{ 'swiper-bundle.min.css' | asset_url | stylesheet_tag }}
<script src="{{ 'swiper-bundle.min.js' | asset_url }}" defer="defer"></script>

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  #pf-slider-{{ section.id }} {
    --pagination-color: {{ section.settings.pagination_color }};
  }
{%- endstyle -%}

<section id="pf-slider-{{ section.id }}" class="pf-slider section-{{ section.id }}-padding color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width">
    <div class="swiper pfSwiper" data-touch-move="{{ section.settings.touch_move }}">
      <div class="swiper-wrapper">

        {% for block in section.blocks %}
          {%- liquid
            assign product = block.settings.product
            assign show_sale_badge = false
            if section.settings.show_sale_badge and product.compare_at_price > product.price
              assign show_sale_badge = true
            endif

            assign title_color = block.settings.title_color
            if title_color == '#111111'
              assign title_color = 'rgb(var(--color-foreground))'
            endif

            assign text_color = block.settings.text_color
            if text_color == '#555555'
              assign text_color = 'rgba(var(--color-foreground), 0.75)'
            endif

            assign badge_bg = block.settings.badge_bg
            if badge_bg == '#111111'
              assign badge_bg = 'rgb(var(--color-foreground))'
            endif

            assign btn_bg = block.settings.button_bg
            if btn_bg == '#111111'
              assign btn_bg = 'rgb(var(--color-button))'
            endif

            assign btn_text = block.settings.button_text
            if btn_text == '#ffffff'
              assign btn_text = 'rgb(var(--color-button-text))'
            endif

            assign btn_text_secondary = block.settings.button_text_secondary
            if btn_text_secondary == '#111111'
              assign btn_text_secondary = 'rgb(var(--color-foreground))'
            endif
          -%}

          <div class="swiper-slide" {{ block.shopify_attributes }}>
            <div class="pf-inner pf-inner--{{ section.settings.image_ratio }}">

              <!-- LEFT: CUSTOM IMAGE ONLY -->
              <div class="pf-image">
               {% if block.settings.custom_image != blank %}
                 <div class="pf-animated-image-wrapper"
                      style="
                        --float-distance: {{ block.settings.float_distance }}px;
                        --float-duration: {{ block.settings.float_speed }}s;
                        --glow-color: {{ block.settings.glow_color }};
                        --glow-strength: {{ block.settings.glow_strength }}px;
                      "
                      data-float="{{ block.settings.enable_float }}"
                      data-glow="{{ block.settings.enable_glow }}">
                   {% capture image_loading %}{% if forloop.first %}eager{% else %}lazy{% endif %}{% endcapture %}
                   {{ block.settings.custom_image | image_url: width: 900 | image_tag: 
                      class: 'pf-animated-image', 
                      loading: image_loading,
                      widths: '200, 400, 600, 900',
                      sizes: '(min-width: 1200px) 500px, 40vw'
                   }}
                 </div>
               {% endif %}
              </div>

              <!-- RIGHT: PRODUCT CONTENT -->
              <div class="pf-content">

                <div class="pf-badges">
                  {% if block.settings.badge_text != blank %}
                    <div class="pf-badge pf-badge--custom"
                         style="--badge-bg: {{ badge_bg }};
                                --badge-color: {{ block.settings.badge_color }};">
                      {{ block.settings.badge_text }}
                    </div>
                  {% endif %}

                  {% if show_sale_badge %}
                    <div class="pf-badge pf-badge--sale">
                      {% if section.settings.sale_badge_type == 'percent' %}
                        {% assign discount = product.compare_at_price | minus: product.price | times: 100.0 | divided_by: product.compare_at_price | round %}
                        -{{ discount }}%
                      {% else %}
                        {{ 'products.product.on_sale' | t | default: 'SALE' }}
                      {% endif %}
                    </div>
                  {% endif %}
                </div>

                {% if product != blank %}

                  {% assign heading_tag = block.settings.heading_tag | default: 'h2' %}
                  <{{ heading_tag }} class="pf-title" style="--title-color: {{ title_color }}; --title-weight: {% if block.settings.title_bold %}700{% else %}400{% endif %};">
                    {{ product.title }}
                  </{{ heading_tag }}>

                  {% if block.settings.custom_text != blank %}
                    <div class="pf-text" style="--text-color: {{ block.settings.text_color }}; --text-weight: {% if block.settings.text_bold %}700{% else %}400{% endif %};">
                      {{ block.settings.custom_text }}
                    </div>
                  {% endif %}

                  <div class="pf-price" style="--price-color: {{ block.settings.price_color }}; --price-size: {{ block.settings.price_size }}rem; --price-weight: {% if block.settings.price_bold %}700{% else %}400{% endif %};">
                    {% if product.compare_at_price > product.price %}
                      <span class="price price--compare">
                        {{ product.compare_at_price | money }}
                      </span>
                    {% endif %}
                    <span class="price">
                      {{ product.price | money }}
                    </span>
                  </div>

                  <div class="pf-buttons" style="
                    --btn-bg: {{ btn_bg }}; 
                    --btn-text: {{ btn_text }}; 
                    --btn-bg-alt: {{ block.settings.button_bg_secondary }}; 
                    --btn-text-alt: {{ btn_text_secondary }};
                  ">

                    <product-form>
                      {% form 'product', product %}
                        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                        <button 
                          type="submit" 
                          class="button button--primary pf-btn-main"
                          {% unless product.available %}disabled{% endunless %}
                        >
                          {% if product.available %}
                            {% if block.settings.btn_primary_text != blank %}
                              {{ block.settings.btn_primary_text }}
                            {% else %}
                              {{ 'products.product.add_to_cart' | t | default: 'Add to cart' }}
                            {% endif %}
                          {% else %}
                            {{ 'products.product.sold_out' | t | default: 'Sold out' }}
                          {% endif %}
                        </button>
                      {% endform %}
                    </product-form>

                    <a href="{{ product.url }}" class="button button--secondary pf-btn-sub">
                      {% if block.settings.btn_secondary_text != blank %}
                        {{ block.settings.btn_secondary_text }}
                      {% else %}
                        {{ 'products.product.view_full_details' | t | default: 'View details' }}
                      {% endif %}
                    </a>

                  </div>

                {% endif %}

              </div>

            </div>
          </div>

        {% endfor %}

      </div>

      {% if section.settings.show_pagination %}
        <div class="swiper-pagination"></div>
      {% endif %}

      {% if section.settings.show_arrows %}
        <div class="swiper-button-prev swiper-button-{{ section.settings.navigation_style }}"></div>
        <div class="swiper-button-next swiper-button-{{ section.settings.navigation_style }}"></div>
      {% endif %}

    </div>
  </div>
</section>

{{ 'section-advanced-product-slider.css' | asset_url | stylesheet_tag }}

<script>
document.addEventListener('DOMContentLoaded', function () {
  const swiperEl = document.querySelector('#pf-slider-{{ section.id }} .pfSwiper');
  if (!swiperEl) return;

  const allowTouch = swiperEl.dataset.touchMove === 'true';

  new Swiper(swiperEl, {
    loop: {{ section.settings.loop }},
    speed: {{ section.settings.speed }},
    allowTouchMove: allowTouch,
    grabCursor: allowTouch,
    watchSlidesProgress: true,

    {% if section.settings.autoplay %}
    autoplay: {
      delay: {{ section.settings.autoplay_speed }},
      disableOnInteraction: false
    },
    {% endif %}

    pagination: {
      el: '#pf-slider-{{ section.id }} .swiper-pagination',
      clickable: true
    },

    navigation: {
      nextEl: '#pf-slider-{{ section.id }} .swiper-button-next',
      prevEl: '#pf-slider-{{ section.id }} .swiper-button-prev'
    },

    breakpoints: {
      320: { autoHeight: true },
      768: { autoHeight: false }
    }
  });
});
</script>

{% schema %}
{
  "name": "Advanced Product Slider",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Farbschema",
      "default": "background-1"
    },
    {
      "type": "header",
      "content": "Verhalten"
    },
    { "type": "checkbox", "id": "autoplay", "label": "Autoplay", "default": true },
    { "type": "range", "id": "autoplay_speed", "min": 2000, "max": 8000, "step": 500, "default": 4000, "label": "Autoplay Geschwindigkeit" },
    { "type": "range", "id": "speed", "min": 300, "max": 2000, "step": 100, "default": 800, "label": "Slide Geschwindigkeit" },
    { "type": "checkbox", "id": "loop", "label": "Endlos-Schleife", "default": true },
    { "type": "checkbox", "id": "touch_move", "label": "Wischen erlauben", "default": true },
    {
      "type": "header",
      "content": "Layout & Design"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Bildformat",
      "options": [
        { "value": "adapt", "label": "Anpassen" },
        { "value": "square", "label": "Quadrat (1:1)" },
        { "value": "portrait", "label": "Porträt (2:3)" }
      ],
      "default": "adapt"
    },
    { "type": "checkbox", "id": "show_pagination", "label": "Pagination anzeigen", "default": true },
    { "type": "color", "id": "pagination_color", "label": "Farbe der Pagination-Punkte", "default": "#000000" },
    { "type": "checkbox", "id": "show_arrows", "label": "Pfeile anzeigen", "default": true },
    {
      "type": "select",
      "id": "navigation_style",
      "label": "Stil der Navigationspfeile",
      "options": [
        { "value": "minimal", "label": "Minimal" },
        { "value": "circle", "label": "Moderner Kreis" }
      ],
      "default": "circle"
    },
    {
      "type": "header",
      "content": "Sale & Badges"
    },
    { "type": "checkbox", "id": "show_sale_badge", "label": "Automatisches Sale-Badge anzeigen", "default": true },
    {
      "type": "select",
      "id": "sale_badge_type",
      "label": "Sale-Badge Typ",
      "options": [
        { "value": "percent", "label": "Prozentual (-20%)" },
        { "value": "text", "label": "Text (SALE)" }
      ],
      "default": "percent"
    },
    {
      "type": "header",
      "content": "Sektions-Abstände"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Abstand oben",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Abstand unten",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "limit": 12,
      "settings": [
        { "type": "image_picker", "id": "custom_image", "label": "Bild hochladen (links)" },
        { "type": "product", "id": "product", "label": "Produkt (rechte Seite)" },
        { "type": "text", "id": "badge_text", "label": "Badge Text", "default": "FEATURED PRODUCT" },
        { "type": "color", "id": "badge_bg", "label": "Badge Hintergrund", "default": "#111111" },
        { "type": "color", "id": "badge_color", "label": "Badge Textfarbe", "default": "#ffffff" },
        { "type": "richtext", "id": "custom_text", "label": "Optionaler Text" },

        { "type": "header", "content": "Schrift & Farben" },

        {
          "type": "select",
          "id": "heading_tag",
          "label": "Titel HTML-Tag (SEO)",
          "options": [
            { "value": "h1", "label": "H1" },
            { "value": "h2", "label": "H2" },
            { "value": "h3", "label": "H3" },
            { "value": "h4", "label": "H4" },
            { "value": "p",  "label": "Text (p)" }
          ],
          "default": "h2"
        },
        { "type": "color", "id": "title_color", "label": "Titel Farbe", "default": "#111111" },
        { "type": "checkbox", "id": "title_bold", "label": "Titel fettgedruckt", "default": true },
        
        { "type": "color", "id": "text_color", "label": "Text Farbe", "default": "#555555" },
        { "type": "checkbox", "id": "text_bold", "label": "Text fettgedruckt", "default": false },
        
        { "type": "color", "id": "price_color", "label": "Preis Farbe", "default": "#dac795" },
        { "type": "range", "id": "price_size", "min": 1.2, "max": 5.0, "step": 0.1, "unit": "rem", "default": 2.4, "label": "Preis Schriftgröße" },
        { "type": "checkbox", "id": "price_bold", "label": "Preis fettgedruckt", "default": true },

        { "type": "header", "content": "Buttons" },
        { "type": "text", "id": "btn_primary_text", "label": "Text Haupt-Button", "placeholder": "z.B. In den Warenkorb" },
        { "type": "color", "id": "button_bg", "label": "1. Button Hintergrund", "default": "#111111" },
        { "type": "color", "id": "button_text", "label": "1. Button Text", "default": "#ffffff" },
        { "type": "text", "id": "btn_secondary_text", "label": "Text Zweiter Button", "placeholder": "z.B. Details ansehen" },
        { "type": "color", "id": "button_bg_secondary", "label": "2. Button Hintergrund", "default": "transparent" },
        { "type": "color", "id": "button_text_secondary", "label": "2. Button Text", "default": "#111111" },

        { "type": "header", "content": "Bild Animation" },

        { "type": "checkbox", "id": "enable_float", "label": "Float Animation aktivieren", "default": true },
        { "type": "range", "id": "float_distance", "label": "Float Höhe (px)", "min": 5, "max": 40, "step": 1, "default": 15 },
        { "type": "range", "id": "float_speed", "label": "Float Geschwindigkeit (Sekunden)", "min": 2, "max": 15, "step": 1, "default": 6 },

        { "type": "checkbox", "id": "enable_glow", "label": "Glow aktivieren", "default": true },
        { "type": "color", "id": "glow_color", "label": "Glow Farbe", "default": "#0096ff" },
        { "type": "range", "id": "glow_strength", "label": "Glow Intensität", "min": 5, "max": 60, "step": 1, "default": 25 }
      ]
    }
  ],
  "presets": [
    {
      "name": "Advanced Product Slider",
      "blocks": [
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}