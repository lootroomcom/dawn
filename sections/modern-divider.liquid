{% comment %}
  Strong Modern Divider – Always Visible
{% endcomment %}

<section class="strong-divider strong-divider-{{ section.id }}">
  <div class="divider-inner">
    {% if section.settings.show_text and section.settings.text != blank %}
      <div class="divider-text">
        <span>{{ section.settings.text }}</span>
      </div>
    {% else %}
      <div class="divider-line"></div>
    {% endif %}
  </div>
</section>

{%- style -%}
.strong-divider-{{ section.id }} {
  --divider-spacing: {{ section.settings.spacing }}px;
  --divider-gradient: linear-gradient(90deg, {{ section.settings.color_1 }}, {{ section.settings.color_2 }}, {{ section.settings.color_3 }});
  --divider-shadow-1: 0 0 15px {{ section.settings.color_2 }};
  --divider-shadow-2: 0 0 30px {{ section.settings.color_3 }};
}
{%- endstyle -%}

{{ 'section-modern-divider.css' | asset_url | stylesheet_tag }}

{% schema %}
{
  "name": "Strong Modern Divider",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_text",
      "label": "Mit Text anzeigen",
      "default": false
    },
    {
      "type": "text",
      "id": "text",
      "label": "Text",
      "default": "Featured"
    },
    {
      "type": "range",
      "id": "spacing",
      "label": "Spacing oben & unten",
      "min": 20,
      "max": 150,
      "step": 10,
      "default": 80
    },
    {
      "type": "color",
      "id": "color_1",
      "label": "Farbe 1",
      "default": "#ff00cc"
    },
    {
      "type": "color",
      "id": "color_2",
      "label": "Farbe 2",
      "default": "#333399"
    },
    {
      "type": "color",
      "id": "color_3",
      "label": "Farbe 3",
      "default": "#00f2fe"
    }
  ],
  "presets": [
    {
      "name": "Strong Modern Divider"
    }
  ]
}
{% endschema %}