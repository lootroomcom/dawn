{% comment %}
  Steam-Style Product Card — Purple/Teal Gradient Variant
  File: snippets/steam-product-card.liquid
  Usage: {% render 'steam-product-card', product: product %}

  Optional product metafields (Shopify Admin → Products → Metafields):
    custom.eyebrow      → e.g. "New Arrival", "Featured", "Collection"
    custom.subtitle     → e.g. "Heavyweight · 400gsm"
    custom.badge        → e.g. "NEW", "COLLAB", "EXCLUSIVE"
    custom.badge_type   → "new" | "sale" | "collab"
    custom.card_tag     → e.g. "LOW STOCK", "DROPS FRI", "LAST ONES"

  Gradient colors can be customised per-product via metafields:
    custom.gradient_color1  → e.g. "#81399a"  (left/purple end)
    custom.gradient_color2  → e.g. "#0094a2"  (mid/teal end)
{% endcomment %}

{% assign card_product = product %}
{% assign first_variant = card_product.selected_or_first_available_variant %}
{% assign compare_price  = first_variant.compare_at_price %}
{% assign current_price  = first_variant.price %}
{% assign on_sale = false %}
{% if compare_price > current_price %}
  {% assign on_sale = true %}
  {% assign discount_pct = compare_price | minus: current_price | times: 100 | divided_by: compare_price %}
{% endif %}

{% assign gc1 = card_product.metafields.custom.gradient_color1 | default: '#81399a' %}
{% assign gc2 = card_product.metafields.custom.gradient_color2 | default: '#0094a2' %}

<a
  href="{{ card_product.url }}"
  class="steam-card"
  style="--gc1: {{ gc1 }}; --gc2: {{ gc2 }};"
  aria-label="{{ card_product.title | escape }}"
>

  {% if card_product.featured_image %}
    <img
      class="steam-card__img"
      src="{{ card_product.featured_image | image_url: width: 600 }}"
      alt="{{ card_product.featured_image.alt | escape }}"
      width="600"
      height="400"
      loading="lazy"
    >
  {% else %}
    <div class="steam-card__img steam-card__img--placeholder"></div>
  {% endif %}

  <div class="steam-card__overlay"></div>

  <div class="steam-card__content">
    {% if card_product.metafields.custom.eyebrow != blank %}
      <span class="steam-card__eyebrow">{{ card_product.metafields.custom.eyebrow }}</span>
    {% endif %}

    <span class="steam-card__title">{{ card_product.title }}</span>

    {% if card_product.metafields.custom.subtitle != blank %}
      <span class="steam-card__subtitle">{{ card_product.metafields.custom.subtitle }}</span>
    {% endif %}

    {% if card_product.metafields.custom.badge != blank %}
      {% assign badge_type = card_product.metafields.custom.badge_type | default: 'new' %}
      <div class="steam-card__badges">
        <span class="steam-card__badge steam-card__badge--{{ badge_type }}">
          {{ card_product.metafields.custom.badge }}
        </span>
      </div>
    {% elsif on_sale %}
      <div class="steam-card__badges">
        <span class="steam-card__badge steam-card__badge--sale">SALE</span>
      </div>
    {% endif %}
  </div>

  {% if card_product.metafields.custom.card_tag != blank %}
    <span class="steam-card__tag">{{ card_product.metafields.custom.card_tag }}</span>
  {% elsif card_product.variants.first.inventory_quantity <= 5 and card_product.variants.first.inventory_quantity > 0 %}
    <span class="steam-card__tag">LOW STOCK</span>
  {% endif %}

  <div class="steam-card__price-area">
    {% if on_sale %}
      <span class="steam-card__discount-pill">-{{ discount_pct }}%</span>
      <span class="steam-card__price-original">{{ compare_price | money }}</span>
      <span class="steam-card__price steam-card__price--sale">{{ current_price | money }}</span>
    {% else %}
      <span class="steam-card__price">{{ current_price | money }}</span>
    {% endif %}
  </div>

</a>

{% comment %}
  ─────────────────────────────────────────────────────────────────
  CSS — paste once into assets/steam-cards.css and include it via
  your theme.liquid, OR paste the <style> block directly into
  your theme.liquid / base.css (remove the style tags in that case).
  ─────────────────────────────────────────────────────────────────
{% endcomment %}
{% unless steam_card_styles_rendered %}
{% assign steam_card_styles_rendered = true %}
<style>
/* ── Animated gradient custom properties ── */
@property --gc1 {
  syntax: "<color>";
  initial-value: #81399a;
  inherits: false;
}
@property --gc2 {
  syntax: "<color>";
  initial-value: #0094a2;
  inherits: false;
}

/* ── Card shell ── */
.steam-card {
  display: block;
  position: relative;
  width: 100%;
  aspect-ratio: 3 / 2;
  overflow: hidden;
  cursor: pointer;
  border-radius: 3px;
  box-shadow: 0px 3px 6px 0px rgba(0, 0, 0, 0.24);
  background: #1b2838;
  text-decoration: none;
  -webkit-user-select: none;
  user-select: none;
  --gc1: #81399a;
  --gc2: #0094a2;
  transition:
    transform 0.2s ease-in-out,
    box-shadow 0.2s ease-in-out,
    --gc1 0.4s ease,
    --gc2 0.4s ease;
}
.steam-card:hover {
  transform: translateY(-3px) scale(1.01);
  box-shadow: 0 10px 24px rgba(0, 0, 0, 0.6);
  --gc1: #9e44bb;
  --gc2: #00b8c8;
}

/* ── Product image ── */
.steam-card__img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.steam-card__img--placeholder {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, #1a2030 0%, #2a3050 50%, #1a1a30 100%);
}

/* ── Gradient overlay (animates on hover via @property) ── */
.steam-card__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    77deg,
    var(--gc1) 0%,
    var(--gc2) 50%,
    rgba(0, 148, 162, 0) 70%
  );
  z-index: 5;
  pointer-events: none;
}

/* ── Text content layer ── */
.steam-card__content {
  position: absolute;
  inset: 0;
  z-index: 6;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: flex-start;
  padding: 0 5%;
  row-gap: 5px;
  pointer-events: none;
}

.steam-card__eyebrow {
  font-family: Arial, Helvetica, sans-serif;
  font-size: 11px;
  font-weight: 400;
  color: rgba(255, 255, 255, 0.55);
  letter-spacing: 1.5px;
  text-transform: uppercase;
}
.steam-card__title {
  font-family: Arial, Helvetica, sans-serif;
  font-size: clamp(14px, 2.5vw, 22px);
  font-weight: 700;
  color: #ffffff;
  line-height: 1.15;
  text-shadow: 0 1px 4px rgba(0, 0, 0, 0.5);
  max-width: 55%;
}
.steam-card__subtitle {
  font-family: Arial, Helvetica, sans-serif;
  font-size: 11px;
  color: rgba(255, 255, 255, 0.65);
}

/* ── Badges ── */
.steam-card__badges {
  display: flex;
  gap: 5px;
  margin-top: 4px;
}
.steam-card__badge {
  font-size: 10px;
  font-weight: 700;
  padding: 3px 8px;
  border-radius: 2px;
  letter-spacing: 0.4px;
  text-transform: uppercase;
}
.steam-card__badge--new {
  background: rgba(161, 205, 68, 0.18);
  color: #a1cd44;
  border: 1px solid rgba(161, 205, 68, 0.3);
}
.steam-card__badge--sale {
  background: rgba(238, 86, 59, 0.18);
  color: #ee563b;
  border: 1px solid rgba(238, 86, 59, 0.3);
}
.steam-card__badge--collab {
  background: rgba(26, 159, 255, 0.18);
  color: #1a9fff;
  border: 1px solid rgba(26, 159, 255, 0.3);
}

/* ── Corner tag ── */
.steam-card__tag {
  position: absolute;
  top: 10px;
  right: 10px;
  z-index: 7;
  background: rgba(0, 0, 0, 0.5);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 2px;
  font-size: 10px;
  color: rgba(255, 255, 255, 0.55);
  padding: 3px 8px;
  letter-spacing: 0.6px;
  text-transform: uppercase;
  font-family: Arial, Helvetica, sans-serif;
}

/* ── Price area ── */
.steam-card__price-area {
  position: absolute;
  bottom: 12px;
  right: 12px;
  z-index: 6;
  text-align: right;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 2px;
}
.steam-card__discount-pill {
  display: inline-block;
  background: #4c6b22;
  color: #a1cd44;
  font-size: 11px;
  font-weight: 700;
  padding: 2px 7px;
  border-radius: 2px;
}
.steam-card__price-original {
  font-size: 11px;
  color: rgba(255, 255, 255, 0.4);
  text-decoration: line-through;
  font-family: Arial, Helvetica, sans-serif;
}
.steam-card__price {
  font-family: Arial, Helvetica, sans-serif;
  font-size: clamp(15px, 2vw, 20px);
  font-weight: 700;
  color: #c6d4df;
  line-height: 1;
}
.steam-card__price--sale {
  color: #a1cd44;
}
</style>
{% endunless %}
