{{ 'section-trust-belt.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .tb-{{ section.id }} {
    --tb-gradient: linear-gradient(-45deg,
      {{ section.settings.gradient_1 }},
      {{ section.settings.gradient_2 }},
      {{ section.settings.gradient_3 }},
      {{ section.settings.gradient_4 }}
    );
    --tb-card-bg: rgba(255, 255, 255, {{ section.settings.card_opacity | divided_by: 100.0 }});
    --tb-radius: {{ section.settings.radius }}px;
    --tb-text: {{ section.settings.text_color }};
  }
{%- endstyle -%}

<section class="trust-belt section-{{ section.id }}-padding tb-{{ section.id }}">
  <div class="tb-bg-animated"></div>
  <div class="page-width tb-page-width">
    <div class="trust-belt__inner tb-card">
      
      {%- if section.blocks.size > 0 or section.settings.shipping_heading != blank -%}
        <div class="trust-belt__shipping">
          {%- if section.settings.shipping_heading != blank -%}
            <span class="trust-belt__heading">{{ section.settings.shipping_heading | escape }}</span>
          {%- endif -%}
          <div class="trust-belt__icons {% if section.settings.grayscale_icons %}trust-belt__icons--grayscale{% endif %}">
            {%- for block in section.blocks -%}
              {%- if block.type == 'shipping' -%}
                <div class="trust-belt__icon-wrapper" {{ block.shopify_attributes }}>
                  {%- if block.settings.image != blank -%}
                    {{ block.settings.image | image_url: width: 120 | image_tag: loading: 'lazy', alt: block.settings.title }}
                  {%- else -%}
                    {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                  {%- endif -%}
                  {%- if block.settings.title != blank -%}
                    <span class="visually-hidden">{{ block.settings.title | escape }}</span>
                  {%- endif -%}
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>
      {%- endif -%}
      
      {%- if shop.enabled_payment_types != blank or section.settings.payment_heading != blank -%}
        <div class="trust-belt__payment">
          {%- if section.settings.payment_heading != blank -%}
            <span class="trust-belt__heading">{{ section.settings.payment_heading | escape }}</span>
          {%- endif -%}
          <div class="trust-belt__icons trust-belt__icons--payment {% if section.settings.grayscale_icons %}trust-belt__icons--grayscale{% endif %}">
            {%- for type in shop.enabled_payment_types -%}
              <span class="trust-belt__icon-wrapper" title="{{ type | replace: '_', ' ' | capitalize }}">
                {{ type | payment_type_svg_tag: class: 'icon icon--full-color' }}
              </span>
            {%- endfor -%}
          </div>
        </div>
      {%- endif -%}

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Trust Belt",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "text",
      "id": "shipping_heading",
      "label": "Überschrift Versand",
      "default": "Versand mit"
    },
    {
      "type": "text",
      "id": "payment_heading",
      "label": "Überschrift Zahlung",
      "default": "Sicher bezahlen"
    },
    {
      "type": "checkbox",
      "id": "grayscale_icons",
      "label": "Moderner Grayscale-Modus",
      "default": true,
      "info": "Zeigt Logos elegant dezent in Grau. Sie werden bei Hover farbig (Best Practice 2026)."
    },
    {
      "type": "header",
      "content": "Premium Styling (Chic Multi Columns Base)"
    },
    { "type": "range", "id": "radius", "label": "Radius", "min": 12, "max": 40, "step": 2, "default": 24 },
    { "type": "range", "id": "card_opacity", "label": "Card Opazität (Glassmorphism)", "min": 0, "max": 100, "step": 1, "default": 80 },
    { "type": "color", "id": "text_color", "label": "Textfarbe", "default": "#111111" },
    { "type": "color", "id": "gradient_1", "label": "Gradient 1", "default": "#ff00cc" },
    { "type": "color", "id": "gradient_2", "label": "Gradient 2", "default": "#333399" },
    { "type": "color", "id": "gradient_3", "label": "Gradient 3", "default": "#00f2fe" },
    { "type": "color", "id": "gradient_4", "label": "Gradient 4", "default": "#4facfe" },
    {
      "type": "checkbox",
      "id": "grayscale_icons",
      "label": "Moderner Grayscale-Modus",
      "default": true,
      "info": "Zeigt Logos elegant dezent in Grau. Sie werden bei Hover farbig (Best Practice 2026)."
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 64
    }
  ],
  "blocks": [
    {
      "type": "shipping",
      "name": "Versanddienstleister",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Logo-Bild",
          "info": "Ein kleines Bild oder Icon des Dienstleisters."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Name (für Barrierefreiheit)",
          "default": "Versand"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust Belt",
      "blocks": [
        {
          "type": "shipping"
        },
        {
          "type": "shipping"
        }
      ]
    }
  ]
}
{% endschema %}
