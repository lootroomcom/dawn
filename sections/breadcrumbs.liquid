{% comment %}
  Lootroom – Breadcrumbs Snippet
  Einbinden mit: {% render 'breadcrumbs' %}
  Funktioniert auf: Produkt-, Kollektions-, Blog- & Artikel-Seiten
{% endcomment %}

<nav class="breadcrumbs" aria-label="Breadcrumb">
  <ol class="breadcrumbs__list">

    {%- comment %} HOME {% endcomment %}
    <li class="breadcrumbs__item">
      <a class="breadcrumbs__link" href="{{ routes.root_url }}">Home</a>
    </li>

    {%- if template.name == 'product' -%}

      {%- if collection != blank -%}
        <li class="breadcrumbs__item breadcrumbs__item--separator" aria-hidden="true">›</li>
        <li class="breadcrumbs__item">
          <a class="breadcrumbs__link" href="{{ collection.url }}">{{ collection.title }}</a>
        </li>
      {%- endif -%}

      <li class="breadcrumbs__item breadcrumbs__item--separator" aria-hidden="true">›</li>
      <li class="breadcrumbs__item breadcrumbs__item--current" aria-current="page">
        {{ product.title }}
      </li>

    {%- elsif template.name == 'collection' -%}

      <li class="breadcrumbs__item breadcrumbs__item--separator" aria-hidden="true">›</li>
      <li class="breadcrumbs__item breadcrumbs__item--current" aria-current="page">
        {{ collection.title }}
      </li>

    {%- elsif template.name == 'blog' -%}

      <li class="breadcrumbs__item breadcrumbs__item--separator" aria-hidden="true">›</li>
      <li class="breadcrumbs__item breadcrumbs__item--current" aria-current="page">
        {{ blog.title }}
      </li>

    {%- elsif template.name == 'article' -%}

      <li class="breadcrumbs__item breadcrumbs__item--separator" aria-hidden="true">›</li>
      <li class="breadcrumbs__item">
        <a class="breadcrumbs__link" href="{{ blog.url }}">{{ blog.title }}</a>
      </li>
      <li class="breadcrumbs__item breadcrumbs__item--separator" aria-hidden="true">›</li>
      <li class="breadcrumbs__item breadcrumbs__item--current" aria-current="page">
        {{ article.title }}
      </li>

    {%- elsif template.name == 'page' -%}

      <li class="breadcrumbs__item breadcrumbs__item--separator" aria-hidden="true">›</li>
      <li class="breadcrumbs__item breadcrumbs__item--current" aria-current="page">
        {{ page.title }}
      </li>

    {%- endif -%}

  </ol>
</nav>

<style>
  .breadcrumbs {
    padding: 12px 0 4px 0;
  }

  .breadcrumbs__list {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 4px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .breadcrumbs__item {
    display: flex;
    align-items: center;
    font-family: Poppins, sans-serif;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(218, 199, 149, 0.55); /* #dac795 gedimmt */
  }

  .breadcrumbs__item--separator {
    color: rgba(218, 199, 149, 0.35);
    font-size: 13px;
    line-height: 1;
    user-select: none;
  }

  .breadcrumbs__link {
    color: rgba(218, 199, 149, 0.55);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .breadcrumbs__link:hover {
    color: #dac795;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .breadcrumbs__item--current {
    color: #dac795;
    font-weight: 600;
    /* lange Produktnamen kappen */
    max-width: 260px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  @media screen and (max-width: 749px) {
    .breadcrumbs {
      padding: 10px 0 2px 0;
    }

    .breadcrumbs__item--current {
      max-width: 180px;
    }
  }
</style>
