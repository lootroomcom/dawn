{%- style -%}
  .trust-bar-{{ section.id }} {
    --tb-text: {{ section.settings.text_color }};
    --tb-accent: {{ section.settings.accent_color }};
    --tb-card: rgba(
      {{ section.settings.card_color.red }},
      {{ section.settings.card_color.green }},
      {{ section.settings.card_color.blue }},
      {{ section.settings.card_opacity | divided_by: 100.0 }}
    );
    --tb-gradient: linear-gradient(-45deg,
      {{ section.settings.gradient_1 }},
      {{ section.settings.gradient_2 }},
      {{ section.settings.gradient_3 }},
      {{ section.settings.gradient_4 }}
    );
    --tb-gradient-2: {{ section.settings.gradient_2 }};
    --tb-radius: {{ section.settings.radius }}px;
    --tb-gap: {{ section.settings.gap }}px;
    --tb-padding-y: {{ section.settings.padding_y }}px;
  }
{%- endstyle -%}

<style>
/* ==========================================================================
   Trust Bar – Matching "Chic Multi Columns ULTRA MAX" Design System
   ========================================================================== */

/* ---- Section Wrapper ---- */
.tb-wrap {
  position: relative;
  padding: var(--tb-padding-y, 60px) 0;
  color: var(--tb-text, #fff);
  overflow: hidden;
}

/* ---- Animated Gradient Background (same as CMC) ---- */
.tb-bg-animated {
  position: absolute;
  inset: 0;
  background: var(--tb-gradient);
  background-size: 600% 600%;
  animation: tbGradientMove 8s ease infinite;
  z-index: -1;
  filter: saturate(1.4);
}

@keyframes tbGradientMove {
  0%   { background-position: 0% 50%; }
  50%  { background-position: 100% 50%; }
  100% { background-position: 0% 50%; }
}

/* ---- Section Header ---- */
.tb-header {
  text-align: center;
  margin-bottom: 40px;
}

.tb-title {
  font-size: clamp(24px, 3.5vw, 36px);
  font-weight: 700;
  margin: 0 0 8px;
  letter-spacing: -0.02em;
}

.tb-subtitle {
  font-size: 15px;
  opacity: 0.65;
  margin: 0;
}

/* ---- Grid ---- */
.tb-grid {
  display: grid;
  gap: var(--tb-gap, 20px);
  position: relative;
  z-index: 2;
}

.tb-grid--features {
  grid-template-columns: repeat(4, 1fr);
  margin-bottom: var(--tb-gap, 20px);
}

.tb-grid--badges {
  grid-template-columns: repeat(2, 1fr);
}

/* ---- Glassmorphism Card (matching CMC) ---- */
.tb-card {
  position: relative;
  border-radius: var(--tb-radius, 24px);
  background: var(--tb-card, rgba(255,255,255,0.06));
  backdrop-filter: blur(28px);
  -webkit-backdrop-filter: blur(28px);
  border: 1px solid rgba(255,255,255,0.12);
  box-shadow:
    0 0 0 1px rgba(255,255,255,0.06),
    0 20px 60px rgba(0,0,0,0.35);
  overflow: hidden;
  transition: transform 0.15s ease, box-shadow 0.3s ease;
  transform-style: preserve-3d;
  animation: tbFloat 6s ease-in-out infinite;
  padding: 24px;
  display: flex;
  align-items: center;
  gap: 16px;
  min-width: 0;
}

@keyframes tbFloat {
  0%, 100% { transform: translateY(0); }
  50%      { transform: translateY(-4px); }
}

/* Neon glow on hover */
.tb-card:hover {
  box-shadow:
    0 0 30px rgba(255,255,255,0.15),
    0 0 5px var(--tb-gradient-2, #1a1a2e),
    0 30px 80px rgba(0,0,0,0.45);
}

/* Shine sweep (matching CMC) */
.tb-card::after {
  content: "";
  position: absolute;
  top: -100%;
  left: -100%;
  width: 200%;
  height: 200%;
  background: linear-gradient(
    120deg,
    transparent 40%,
    rgba(255,255,255,0.25) 50%,
    transparent 60%
  );
  transform: rotate(25deg);
  transition: all 0.7s ease;
  opacity: 0;
  pointer-events: none;
}

.tb-card:hover::after {
  top: 100%;
  left: 100%;
  opacity: 1;
}

/* Mouse-follow light (matching CMC) */
.tb-light {
  position: absolute;
  width: 350px;
  height: 350px;
  background: radial-gradient(circle,
    rgba(255,255,255,0.5),
    rgba(255,255,255,0.15),
    transparent 60%);
  pointer-events: none;
  transform: translate(-50%, -50%);
  opacity: 0;
  transition: opacity 0.2s;
}

.tb-card:hover .tb-light {
  opacity: 1;
}


/* ---- Card Typography (matching CMC sizes) ---- */
.tb-card-body {
  display: flex;
  flex-direction: column;
  gap: 2px;
  min-width: 0;
}

.tb-card-title {
  margin: 0;
  font-size: 15px;
  font-weight: 600;
  line-height: 1.3;
}

.tb-card-title--center {
  text-align: center;
  width: 100%;
  margin-bottom: 12px;
  font-size: 13px;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  opacity: 0.7;
}

.tb-card-text {
  margin: 0;
  font-size: 13px;
  opacity: 0.6;
  line-height: 1.35;
}

/* ---- Badges Card ---- */
.tb-card--badges {
  flex-direction: column;
  align-items: center;
  padding: 28px 24px;
  gap: 16px;
}

/* ---- Payment Icons ---- */
.tb-icons {
  display: flex;
  align-items: center;
  gap: 10px;
  flex-wrap: wrap;
  justify-content: center;
}

svg.tb-pay-icon {
  display: block;
  width: 40px !important;
  height: 24px !important;
  max-width: 40px !important;
  max-height: 24px !important;
}

svg.tb-pay-icon {
  opacity: 0.55;
  transition: opacity 0.25s ease, transform 0.25s ease;
  overflow: hidden;
  flex-shrink: 0;
}

svg.tb-pay-icon:hover {
  opacity: 1;
  transform: scale(1.12);
}

/* ---- Shipping Icons ---- */
.tb-icons--shipping {
  gap: 24px;
}

.tb-ship-text {
  font-size: 13px;
  font-weight: 600;
  letter-spacing: 0.05em;
  padding: 6px 14px;
  background: rgba(255,255,255,0.08);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 20px;
  color: var(--tb-icon, var(--tb-text));
  transition: all 0.25s ease;
}

.tb-ship-text:hover {
  background: rgba(255,255,255,0.15);
  border-color: var(--tb-accent);
  transform: translateY(-2px);
}

/* ---- Responsive (matching CMC mobile behavior) ---- */
@media (max-width: 989px) {
  .tb-grid--features {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 749px) {
  .tb-grid--features {
    grid-auto-flow: column;
    grid-auto-columns: 85%;
    grid-template-columns: unset;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    padding-bottom: 8px;
  }

  .tb-grid--features .tb-card-wrapper {
    scroll-snap-align: start;
  }

  .tb-grid--badges {
    grid-template-columns: 1fr;
  }

  .tb-card {
    padding: 20px;
  }

  .tb-ship-text {
    font-size: 12px;
    padding: 5px 12px;
  }

  svg.tb-pay-icon {
    width: 34px !important;
    height: 20px !important;
    max-width: 34px !important;
    max-height: 20px !important;
  }
}
</style>

<section class="tb-wrap trust-bar-{{ section.id }}">
  <div class="tb-bg-animated"></div>

  <div class="tb-inner page-width">

    {%- if section.settings.title != blank -%}
      <header class="tb-header">
        <h2 class="tb-title">{{ section.settings.title }}</h2>
        {%- if section.settings.subtitle != blank -%}
          <p class="tb-subtitle">{{ section.settings.subtitle }}</p>
        {%- endif -%}
      </header>
    {%- endif -%}

    {%- if section.settings.show_trust_features -%}
      <div class="tb-grid tb-grid--features">
        <div class="tb-card-wrapper">
          <article class="tb-card">
            <div class="tb-card-body">
              <h3 class="tb-card-title">{{ section.settings.feature_1_title }}</h3>
              <p class="tb-card-text">{{ section.settings.feature_1_sub }}</p>
            </div>
            <div class="tb-light"></div>
          </article>
        </div>
        <div class="tb-card-wrapper">
          <article class="tb-card">
            <div class="tb-card-body">
              <h3 class="tb-card-title">{{ section.settings.feature_2_title }}</h3>
              <p class="tb-card-text">{{ section.settings.feature_2_sub }}</p>
            </div>
            <div class="tb-light"></div>
          </article>
        </div>
        <div class="tb-card-wrapper">
          <article class="tb-card">
            <div class="tb-card-body">
              <h3 class="tb-card-title">{{ section.settings.feature_3_title }}</h3>
              <p class="tb-card-text">{{ section.settings.feature_3_sub }}</p>
            </div>
            <div class="tb-light"></div>
          </article>
        </div>
        <div class="tb-card-wrapper">
          <article class="tb-card">
            <div class="tb-card-body">
              <h3 class="tb-card-title">{{ section.settings.feature_4_title }}</h3>
              <p class="tb-card-text">{{ section.settings.feature_4_sub }}</p>
            </div>
            <div class="tb-light"></div>
          </article>
        </div>
      </div>
    {%- endif -%}

    <div class="tb-grid tb-grid--badges">

      {%- if section.settings.show_payments -%}
        <div class="tb-card-wrapper">
          <article class="tb-card tb-card--badges">
            {%- if section.settings.payment_heading != blank -%}
              <h3 class="tb-card-title tb-card-title--center">{{ section.settings.payment_heading }}</h3>
            {%- endif -%}
            <div class="tb-icons">
              {%- for type in shop.enabled_payment_types -%}
                {{ type | payment_type_svg_tag: class: 'tb-pay-icon' }}
              {%- endfor -%}
            </div>
            <div class="tb-light"></div>
          </article>
        </div>
      {%- endif -%}

      {%- if section.settings.show_shipping -%}
        <div class="tb-card-wrapper">
          <article class="tb-card tb-card--badges">
            {%- if section.settings.shipping_heading != blank -%}
              <h3 class="tb-card-title tb-card-title--center">{{ section.settings.shipping_heading }}</h3>
            {%- endif -%}
            <div class="tb-icons tb-icons--shipping">

              {%- if section.settings.show_dhl -%}
                <span class="tb-ship-text" title="DHL">DHL</span>
              {%- endif -%}

              {%- if section.settings.show_usps -%}
                <span class="tb-ship-text" title="USPS">USPS</span>
              {%- endif -%}

              {%- if section.settings.show_auspost -%}
                <span class="tb-ship-text" title="Australia Post">AUS POST</span>
              {%- endif -%}

              {%- if section.settings.show_royalmail -%}
                <span class="tb-ship-text" title="Royal Mail">ROYAL MAIL</span>
              {%- endif -%}

            </div>
            <div class="tb-light"></div>
          </article>
        </div>
      {%- endif -%}

    </div>

  </div>
</section>

<script>
document.querySelectorAll(".trust-bar-{{ section.id }} .tb-card").forEach(card => {
  const light = card.querySelector(".tb-light");
  card.addEventListener("mousemove", e => {
    const rect = card.getBoundingClientRect();
    const x = e.clientX - rect.left;
    const y = e.clientY - rect.top;
    if (light) {
      light.style.left = x + "px";
      light.style.top = y + "px";
    }
  });
  card.addEventListener("mouseleave", () => {
    card.style.transform = "scale(1)";
  });
});
</script>

{% schema %}
{
  "name": "Trust Bar",
  "settings": [
    { "type": "text", "id": "title", "label": "Titel", "default": "" },
    { "type": "text", "id": "subtitle", "label": "Untertitel", "default": "" },

    { "type": "header", "content": "Trust-Features" },

    { "type": "checkbox", "id": "show_trust_features", "label": "Trust-Features anzeigen", "default": true },
    { "type": "text", "id": "feature_1_title", "label": "Feature 1 – Titel", "default": "Sicherer Checkout" },
    { "type": "text", "id": "feature_1_sub", "label": "Feature 1 – Untertitel", "default": "256-Bit SSL Verschlüsselung" },
    { "type": "text", "id": "feature_2_title", "label": "Feature 2 – Titel", "default": "Weltweiter Versand" },
    { "type": "text", "id": "feature_2_sub", "label": "Feature 2 – Untertitel", "default": "Schneller & zuverlässiger Versand" },
    { "type": "text", "id": "feature_3_title", "label": "Feature 3 – Titel", "default": "24/7 Support" },
    { "type": "text", "id": "feature_3_sub", "label": "Feature 3 – Untertitel", "default": "Wir sind immer für dich da" },
    { "type": "text", "id": "feature_4_title", "label": "Feature 4 – Titel", "default": "Zufriedenheitsgarantie" },
    { "type": "text", "id": "feature_4_sub", "label": "Feature 4 – Untertitel", "default": "30 Tage Rückgaberecht" },

    { "type": "header", "content": "Zahlungsmethoden" },

    { "type": "checkbox", "id": "show_payments", "label": "Zahlungsmethoden anzeigen", "default": true },
    { "type": "text", "id": "payment_heading", "label": "Überschrift", "default": "Sichere Bezahlung" },

    { "type": "header", "content": "Versanddienstleister" },

    { "type": "checkbox", "id": "show_shipping", "label": "Versanddienstleister anzeigen", "default": true },
    { "type": "text", "id": "shipping_heading", "label": "Überschrift", "default": "Weltweiter Versand mit" },
    { "type": "checkbox", "id": "show_dhl", "label": "DHL anzeigen", "default": true },
    { "type": "checkbox", "id": "show_usps", "label": "USPS anzeigen", "default": true },
    { "type": "checkbox", "id": "show_auspost", "label": "Australia Post anzeigen", "default": true },
    { "type": "checkbox", "id": "show_royalmail", "label": "Royal Mail anzeigen", "default": true },

    { "type": "header", "content": "Design" },

    { "type": "range", "id": "padding_y", "label": "Section Padding", "min": 20, "max": 120, "step": 4, "default": 60 },
    { "type": "range", "id": "gap", "label": "Card Abstand", "min": 10, "max": 30, "step": 2, "default": 20 },
    { "type": "range", "id": "radius", "label": "Card Radius", "min": 12, "max": 30, "step": 2, "default": 24 },
    { "type": "color", "id": "card_color", "label": "Card Farbe", "default": "#ffffff" },
    { "type": "range", "id": "card_opacity", "label": "Card Opazität (%)", "min": 0, "max": 100, "step": 1, "default": 6 },
    { "type": "color", "id": "text_color", "label": "Textfarbe", "default": "#ffffff" },
    { "type": "color", "id": "accent_color", "label": "Akzentfarbe (Icons)", "default": "#dac795" },
    { "type": "color", "id": "gradient_1", "label": "Gradient 1", "default": "#0a0a0a" },
    { "type": "color", "id": "gradient_2", "label": "Gradient 2", "default": "#1a1a2e" },
    { "type": "color", "id": "gradient_3", "label": "Gradient 3", "default": "#16213e" },
    { "type": "color", "id": "gradient_4", "label": "Gradient 4", "default": "#0f3460" }
  ],
  "presets": [
    {
      "name": "Trust Bar"
    }
  ]
}
{% endschema %}
